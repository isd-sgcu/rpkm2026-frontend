---
import BaseLayout from "@layouts/BaseLayout.astro";
import WalkRallyLayout from "@layouts/WalkRallyLayout.astro";
import { ActivityDetailPanel } from "@components/walkrally/events/ActivityDetailPanel";
import walkrally from "@components/walkrally/events/events.json";

export function getStaticPaths() {
  return [
    ...walkrally.workshop.map((entry) => ({
      params: { id: entry.id },
      props: { entry, tab: "workshop" },
    })),
    ...walkrally.walkingTour.map((entry) => ({
      params: { id: entry.id },
      props: { entry, tab: "walkingTour" },
    })),
  ];
}

const { entry, tab } = Astro.props;
const navigateBack = `/walkrally/events?tab=${tab}`;
---

<BaseLayout title={entry.nameTh}>
  <WalkRallyLayout bgColor="beige" navigateBack={navigateBack}>
    <ActivityDetailPanel entry={entry} client:load />
  </WalkRallyLayout>
</BaseLayout>

import JigsawLayout from "@layouts/JigsawLayout.astro";
import "../../styles/global.css";
import { JigsawScanPanel } from "@components/jigsaw/JigsawScanPanel";
---

<BaseLayout title="RPKM Jigsaw Journey | Scan">
  <JigsawLayout navigateBack="/">
    <div class="flex w-full max-w-sm flex-col items-center gap-6 p-4">
      <h1 class="text-3xl font-bold">สแกนเพื่อรับจิกซอร์</h1>
      <JigsawScanPanel client:load />
    </div>
  </JigsawLayout>
</BaseLayout>

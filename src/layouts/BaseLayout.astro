---
import { Footer, type FooterVariant } from "@components/shared/Footer";
import { AuthGuard } from "@components/shared/AuthGuard";
import { Toaster } from "@components/ui/sonner";
import { cn } from "@lib/utils";
import "@styles/global.css";

type Props = {
  title: string;
  description?: string;
  showFooter?: boolean;
  footerVariant?: FooterVariant;
};

const {
  title,
  description = "RPKM 2026 frontend application",
  showFooter = false,
  footerVariant = "default",
} = Astro.props;
---

<!doctype html>
<html lang="en" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans">
    <script is:inline>
      const userAgent = navigator.userAgent;
      if (/Line\//.test(userAgent)) {
        const url = new URL(location.href);
        url.searchParams.append("openExternalBrowser", "1");
        location.href = url.toString();
      }
    </script>

    <AuthGuard client:load pathname={Astro.url.pathname} />
    <Toaster client:load />
    <main
      class={cn(
        "grid relative z-1",
        footerVariant === "landing"
          ? // An auto column sizes to the artwork's intrinsic 402px and centring
            // shrink-wraps it; the landing art is full-bleed, so pin the column
            // to the viewport instead.
            "grid-cols-1 place-items-stretch"
          : cn(
              "place-items-center",
              "sm:max-w-md sm:mx-auto",
              showFooter ? "min-h-[calc(100vh-1rem)]" : "min-h-screen",
            ),
      )}
    >
      <slot />
    </main>
    {showFooter && <Footer variant={footerVariant} client:load />}
  </body>
</html>

---
import { NavigationMenu } from "@components/shared/NavigationMenu";
import Image from "astro/components/Image.astro";
import logo from "../assets/images/artboard_1.svg";
import { ChevronLeft } from "lucide-react";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  navigateBack?: string;
  showMenu?: boolean;
  showLogo?: boolean;
}

const {
  navigateBack = "",
  showMenu = true,
  showLogo = true,
  ...rest
} = Astro.props;
---

<div class:list={["relative w-full min-w-0 min-h-screen"]} {...rest}>
  {
    showLogo && (
      <div class="absolute left-0 right-0 top-[4.5cqw] sm:top-5 grid place-items-center">
        <Image src={logo} alt="rpkm logo" class="h-[40cqw] sm:h-45 w-fit" />
      </div>
    )
  }

  {
    navigateBack && (
      <div class="absolute left-4 top-[4.5cqw] sm:top-4.5 h-10 flex items-center z-10">
        <a
          href={navigateBack}
          class="size-10 rounded-full bg-white border border-black grid place-items-center"
        >
          <ChevronLeft className="size-6.5 text-foreground" />
        </a>
      </div>
    )
  }

  {
    showMenu && (
      <div class="absolute right-4 top-[2.5cqw] sm:top-2.5 flex items-center">
        <NavigationMenu client:load />
      </div>
    )
  }

  <div
    class:list={[
      "inset-0 flex flex-col px-[1.25em] pointer-events-none",
      showLogo ? "absolute pt-[40cqw] sm:pt-45" : "relative",
    ]}
  >
    <div class="contents pointer-events-auto">
      <slot />
    </div>
  </div>
</div>

---
import { NavigationMenu } from "@components/shared/NavigationMenu";
import Image from "astro/components/Image.astro";
import logo from "../assets/images/rpkm_logo.png";
import { ChevronLeft } from "lucide-react";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  navigateBack?: string;
  showMenu?: boolean;
  showLogo?: boolean;
}

const {
  navigateBack = "",
  showMenu = true,
  showLogo = true,
  ...rest
} = Astro.props;
---

<div class:list={["relative w-full min-h-200"]} {...rest}>
  {
    showLogo && (
      <div class="absolute left-0 right-0 top-[8.5cqw] grid place-items-center">
        <Image src={logo} alt="rpkm logo" class="h-[40cqw] w-fit" />
      </div>
    )
  }

  {
    navigateBack && (
      <div class="absolute left-4 right-4 top-[4.5cqw] flex items-center">
        <a href={navigateBack}>
          <ChevronLeft className="size-6.5 text-foreground" />
        </a>
      </div>
    )
  }

  {
    showMenu && (
      <div class="absolute right-4 top-[2.5cqw] flex items-center">
        <NavigationMenu client:load />
      </div>
    )
  }

  <div
    class="absolute inset-0 flex flex-col px-[1.25em] pt-[40cqw] pointer-events-none"
  >
    <div class="contents pointer-events-auto">
      <slot />
    </div>
  </div>
</div>
